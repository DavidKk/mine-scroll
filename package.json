{
  "name": "chill-minesweeper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "commit": "git-cz",
    "ci": "pnpm format:check && pnpm lint:ci && pnpm typecheck && pnpm test",
    "ci:coverage": "pnpm test",
    "postinstall": "node --experimental-modules ./scripts/postinstall.mjs",
    "preinstall": "node --experimental-modules ./scripts/preinstall.mjs",
    "clear": "rimraf --glob ./{.next,coverage,junit.xml,tsconfig.tsbuildinfo}",
    "format": "prettier --config .prettierrc.cjs --write \"**/*.{js,jsx,ts,tsx,d.ts,vue,md,json,yml,yaml,mjs,cjs}\"",
    "format:check": "prettier --config .prettierrc.cjs --check \"**/*.{js,jsx,ts,tsx,d.ts,vue,md,json,yml,yaml,mjs,cjs}\"",
    "lint": "pnpm lint:ts",
    "lint:ts": "eslint -c eslint.config.mjs --fix .",
    "lint:ci": "eslint -c eslint.config.mjs --max-warnings 0 .",
    "typecheck": "tsc --noEmit",
    "dev": "next dev --webpack",
    "dev:e2e": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "pnpm build:assets && next build --webpack",
    "build:assets": "node --experimental-strip-types scripts/optimize-boot-webp.ts && node --experimental-strip-types scripts/gen-boot-manifest.ts && node --experimental-strip-types scripts/gen-service-worker.ts",
    "start": "next start",
    "test": "jest -c ./jest.config.ts --coverage --reporters=default --reporters=jest-junit --passWithNoTests",
    "test:legacy": "node --experimental-strip-types scripts/run-tests.ts",
    "test:watch": "jest --watch",
    "ok": "pnpm format && pnpm lint && pnpm build && pnpm test",
    "assets:boot-manifest": "node --experimental-strip-types scripts/gen-boot-manifest.ts",
    "assets:boot-webp": "node --experimental-strip-types scripts/optimize-boot-webp.ts",
    "assets:service-worker": "node --experimental-strip-types scripts/gen-service-worker.ts",
    "simulate:ai": "node --experimental-strip-types scripts/simulate-endless-ai.ts",
    "assets:tiles": "python3 scripts/optimize-tiles.py",
    "assets:hud": "python3 scripts/slice-brief-hud.py",
    "assets:production": "python3 scripts/slice-production-assets.py",
    "assets:gameplay": "python3 scripts/generate-gameplay-assets.py",
    "assets:all": "python3 scripts/optimize-tiles.py && python3 scripts/slice-brief-hud.py && python3 scripts/slice-production-assets.py && python3 scripts/generate-gameplay-assets.py",
    "prepare": "husky"
  },
  "dependencies": {
    "@shared/core": "workspace:*",
    "@upstash/redis": "^1.37.0",
    "cookie": "^1.0.2",
    "next": "^16.1.0",
    "otplib": "^12.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/eslintrc": "^3",
    "@jest/types": "^29.6.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "chalk": "^5.3.0",
    "commitizen": "^4.2.4",
    "commitlint-plugin-i18n": "^0.0.1-alpha.3",
    "concurrently": "^9.2.0",
    "cz-customizable": "^7.2.1",
    "cz-customizable-i18n-config": "^0.0.1-alpha.2",
    "eslint": "^9",
    "eslint-config-next": "^16.1.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "json5": "^2.2.3",
    "lint-staged": "^15.2.7",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "pretty-error": "^4.0.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.35.2",
    "spinnies": "^0.5.1",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
