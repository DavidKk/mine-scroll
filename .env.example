# ============================================
# Required (session signing)
# ============================================

# Secret key used to sign local session JWT cookies
JWT_SECRET=""

# Session duration for "remember me" (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN="7d"

# ============================================
# Production admin login — Signet (vercel-2fa)
# ============================================

# Server-only: full URL to hosted `signet-client.mjs`.
# Auth center origin is inferred when the path ends with `signet-client.mjs`.
# Register callback in auth center ALLOWED_REDIRECT_URLS:
#   https://your-app.example.com/auth/vercel-2fa/callback
SIGNET_SDK_URL="https://vercel-2fa.vercel.app/sdk/signet-client.mjs"

# ============================================
# Local development only (disabled in production)
# ============================================

# ACCESS_USERNAME="admin"
# ACCESS_PASSWORD="123456"

# Optional TOTP for local login — generate at https://vercel-2fa.vercel.app
# ACCESS_2FA_SECRET=""

# ============================================
# Third-party OAuth login (ECDH + Vercel 2FA)
# ============================================

# OAuth authorization page (defaults to vercel-2fa)
# NEXT_PUBLIC_OAUTH_LOGIN_URL="https://vercel-2fa.vercel.app/oauth"

# Server ECDH public key — required to enable the OAuth login button
# NEXT_PUBLIC_OAUTH_SERVER_PUBLIC_KEY=""

# JWT secret used to verify tokens from the OAuth provider (falls back to JWT_SECRET)
# OAUTH_JWT_SECRET=""

# ACCESS_USERNAME must match the username claim in third-party OAuth tokens

# ============================================
# Leaderboard + Ranked runs (Upstash Redis / Vercel KV)
# ============================================

# Vercel Dashboard → Project → Storage → Link KV, then:
#   vercel env pull .env.local
#
# Vercel injects KV_REST_API_*; Upstash console uses UPSTASH_REDIS_REST_*.
#
# Development: if neither is set, ranked + leaderboard use in-process memory
# (data clears when the dev server restarts).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""
