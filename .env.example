# ============================================
# Required Environment Variables
# ============================================
# Auth naming aligns with vercel-web-scripts and vercel-openapi.

# Admin Username
# Username for admin panel access. Also required to validate third-party OAuth tokens (all environments).
ACCESS_USERNAME="admin"

# Admin Password
# Password for local username/password login.
# MineScroll ignores username/password login in production — use Signet instead.
ACCESS_PASSWORD="123456"

# JWT Secret
# Secret key used to sign session JWT cookies. Required in production.
# Security: use a strong random string (at least 32 characters).
JWT_SECRET=""

# JWT Token Expiration Time
# Session duration for "remember me" (e.g. 7d, 24h, 1h). Code default when unset: 1d.
JWT_EXPIRES_IN="7d"

# ============================================
# Optional Environment Variables
# ============================================

# 2FA Secret (optional)
# TOTP for local login — generate at https://vercel-2fa.vercel.app
# ACCESS_2FA_SECRET=""

# Custom third-party login URL (optional)
# NEXT_PUBLIC_OAUTH_LOGIN_URL="https://vercel-2fa.vercel.app/oauth"

# Third-party server public key for ECDH decryption (optional)
# Enables the OAuth login button when set.
# NEXT_PUBLIC_OAUTH_SERVER_PUBLIC_KEY=""

# Third-party JWT signing secret (optional)
# Verifies tokens from the OAuth provider. Falls back to JWT_SECRET.
# OAUTH_JWT_SECRET=""

# Vercel 2FA / Signet (production admin login)
# Demo callback: https://your-app.example.com/auth/vercel-2fa/callback
# Register that URL in the auth center ALLOWED_REDIRECT_URLS.
#
# Server-only: prefer SIGNET_SDK_URL (path must end with signet-client.mjs).
# NEXT_PUBLIC_SIGNET_SDK_URL is accepted as a server-side fallback (vercel-openapi).
# Do not rely on NEXT_PUBLIC_* alone — MineScroll reads Signet config on the server.
#
# Optional Signet overrides (vercel-openapi):
# SIGNET_ORIGIN=""          — auth center origin when it differs from the SDK URL host
# ENABLE_SIGNET_LOGIN="0"   — hide Signet login entry
SIGNET_SDK_URL="https://vercel-2fa.vercel.app/sdk/signet-client.mjs"
ENABLE_SIGNET_LOGIN="1"

# Vercel Dashboard: paste values without surrounding quotes (quotes break URL validation).

# ============================================
# Leaderboard + Ranked runs (MineScroll KV / Redis)
# ============================================

# Set these on Vercel (or locally) for ranked runs + leaderboard.
# Prefer REST API URL + write token for @upstash/redis.
#
# Development: if URL + token are unset, ranked + leaderboard use in-process
# memory (data clears when the dev server restarts).
#
# MINE_SCROLL_KV_REST_API_URL=""
# MINE_SCROLL_KV_URL=""
# MINE_SCROLL_REDIS_URL=""
# MINE_SCROLL_KV_REST_API_TOKEN=""
# MINE_SCROLL_KV_REST_API_READ_ONLY_TOKEN=""

# ============================================
# Mobile dev tunnel (pnpm dev:ngrok)
# ============================================

# ngrok authtoken — https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=""
